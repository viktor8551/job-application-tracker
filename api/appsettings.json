{
  "Attachments": {
    "MaxFiles": 5,
    "MaxFileSizeMiB": 10,
    "AllowedExtensions": [
      ".pdf",
      ".doc",
      ".docx",
      ".txt",
      ".rtf",
      ".odt"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
